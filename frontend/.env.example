# GridIndex Frontend — Environment Variables
# Copy to .env.local for local development (Vite dev server proxy handles /api)
# Set in Vercel dashboard for production

# Backend API URL (no trailing slash, no /api suffix)
# Leave blank in development — Vite proxy handles it via vite.config.js
# Example: https://gridindex-api.up.railway.app
VITE_API_BASE_URL=
