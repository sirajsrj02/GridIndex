# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=debug

# Database (Supabase)
DATABASE_URL=postgresql://postgres:[password]@[project].supabase.co:5432/postgres
DATABASE_SSL=true

# Authentication
JWT_SECRET=generate_with__node_-e_console.log(require('crypto').randomBytes(64).toString('hex'))
JWT_EXPIRES_IN=7d
API_KEY_PREFIX=gp_

# EIA API (free at eia.gov/opendata)
EIA_API_KEY=your_eia_api_key_here

# IEA API (free at iea.org/api)
IEA_API_KEY=your_iea_api_key_here

# DOE NREL API (free at developer.nrel.gov/signup)
NREL_API_KEY=your_nrel_api_key_here

# PJM Data Miner (free at dataminer2.pjm.com)
PJM_API_KEY=your_pjm_key_here

# ISO-NE (free at iso-ne.com)
ISONE_USERNAME=your_username
ISONE_PASSWORD=your_password

# Email (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM_NAME=GridIndex Alerts
EMAIL_FROM_ADDRESS=alerts@gridindex.io

# Webhook security
WEBHOOK_SIGNING_SECRET=generate_with__node_-e_console.log(require('crypto').randomBytes(32).toString('hex'))

# Sentry (free tier)
SENTRY_DSN=your_sentry_dsn

# Admin master key
ADMIN_API_KEY=generate_with__node_-e_console.log(require('crypto').randomBytes(32).toString('hex'))
